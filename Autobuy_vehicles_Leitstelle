        updateProgress(0, 0, 1);

        try {
          await autobuyForLeitstelle(buildingId, DELAY_PER_VEHICLE, DELAY_PER_BUILDING, DELAY_AFTER_FETCH);
        } catch (e) {
          console.error('[Autobuy Vehicles] Leitstellenlauf fehlgeschlagen', e);
          setState('Fehler beim Leitstellenlauf', 'danger');
        }

        sessionStorage.removeItem(RUN_FLAG);
        btn.classList.remove('disabled');
