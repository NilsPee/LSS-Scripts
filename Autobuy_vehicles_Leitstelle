      const save = async () => {
        const arr = [];
        row.querySelectorAll('input[data-vehicle-id]').forEach(input => {
          const vid = parseInt(input.dataset.vehicleId, 10);
          const cnt = parseInt(input.value, 10);
          if (Number.isInteger(cnt) && cnt > 0) {
            arr.push([vid, cnt]);
          }
        });
        await GM_setValue(key, JSON.stringify(arr));
      };

      row.querySelectorAll('input[data-vehicle-id]').forEach(input => {
        input.addEventListener('change', save);
      });
    }

    const rows = [];
    for (const t of BUILDING_TYPES) rows.push(createTypeRow(t));
    for (const r of rows) await initRowState(r);

    return;
  }

  //----------------------------------------------
  // API-SPEICHER / INDEXEDDB
  //----------------------------------------------
  async function loadApiBuildingsFromCache(maxAgeSeconds = 60) {
    if (typeof openDb !== 'function' || typeof updateBuildings !== 'function') {
      throw new Error('API-Speicher ist nicht verfügbar.');
    }

    const db = await openDb();
    await updateBuildings(db, maxAgeSeconds);

    const tryLoaders = [
      async () => {
        if (typeof getDataByIndex !== 'function') return null;
        return await getDataByIndex(db, 'buildings', 'building_type', IDBKeyRange.bound(0, 999));
      },
      async () => {
        if (typeof getDataByIndex !== 'function') return null;
        return await getDataByIndex(db, 'buildings', 'building_type', IDBKeyRange.lowerBound(0));
      },
      async () => {
        if (typeof getAllData !== 'function') return null;
        return await getAllData(db, 'buildings');
      },
      async () => {
        if (typeof getData !== 'function') return null;
        return await getData(db, 'buildings');
      },
      async () => {
        return await new Promise((resolve, reject) => {
          const transaction = db.transaction('buildings', 'readonly');
          const store = transaction.objectStore('buildings');
          const request = store.getAll();
          request.onsuccess = () => resolve(request.result || []);
          request.onerror = () => reject(request.error || new Error('Gebäude konnten nicht aus IndexedDB geladen werden.'));
        });
      }
    ];

    let lastError = null;

    for (const loader of tryLoaders) {
      try {
        const data = await loader();
        if (Array.isArray(data)) {
          console.log('[Autobuy Vehicles] Gebäude aus API-Speicher geladen:', data.length);
          return data.map(normalizeApiBuilding);
        }
      } catch (e) {
        lastError = e;
        console.warn('[Autobuy Vehicles] Gebäude-Loader fehlgeschlagen, versuche nächsten Loader:', e);
      }
    }

    throw lastError || new Error('Keine Gebäude aus API-Speicher geladen.');
  }

  async function getBuildingsOfLeitstelleFromApi(leitstellenId) {
    const targetId = Number(leitstellenId);
    const allBuildings = await loadApiBuildingsFromCache(60);

    return allBuildings
      .filter(b => b.leitstelle_building_id === targetId)
      .filter(b => isSupportedType(b.building_type))
      .filter(b => !buildingsIDToIgnore.includes(Number(b.building_type)))
      .sort((a, b) => a.id - b.id);
  }

  async function getApiBuildingById(buildingId) {
    const id = Number(buildingId);
    const allBuildings = await loadApiBuildingsFromCache(60);
    return allBuildings.find(b => Number(b.id) === id) || null;
  }

  //----------------------------------------------
  // HTML-FALLBACK FÜR GEBÄUDE
  //----------------------------------------------
  async function getBuildingsOfLeitstelleFallback(leitstellenId, delayAfterFetch) {
    const out = [];

    try {
      const res = await fetch(`/buildings/${leitstellenId}/leitstelle-buildings`, { credentials: 'same-origin' });
      const html = await res.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const links = Array.from(doc.querySelectorAll("a[href^='/buildings/']"));
      const seen = new Set();

      for (const a of links) {
        const id = Number(a.getAttribute('href').split('/buildings/')[1].split('/')[0]);
        if (!Number.isFinite(id) || seen.has(id)) continue;
        seen.add(id);

        try {
          const page = await fetch(`/buildings/${id}`, { credentials: 'same-origin' });
          const pageHtml = await page.text();
          const pageDoc = new DOMParser().parseFromString(pageHtml, 'text/html');
          const h1 = pageDoc.querySelector('h1[building_type]');
          const type = h1 ? Number(h1.getAttribute('building_type')) : null;
          if (!isSupportedType(type) || buildingsIDToIgnore.includes(type)) continue;

          out.push({
            id,
            name: pageDoc.querySelector('h1')?.textContent?.trim() || a.innerText.trim() || `Gebäude ${id}`,
            type,
            building_type: type,
            leitstelle_building_id: Number(leitstellenId)
          });

          if (delayAfterFetch > 0) await delay(delayAfterFetch);
        } catch (e) {
          console.warn('[Autobuy Vehicles] Fallback-Gebäude konnte nicht geladen werden:', id, e);
        }
      }
    } catch (e) {
      console.error('[Autobuy Vehicles] HTML-Fallback fehlgeschlagen:', e);
    }

    return out;
  }

  async function getBuildingsOfLeitstelle(leitstellenId, delayAfterFetch) {
    try {
      const buildings = await getBuildingsOfLeitstelleFromApi(leitstellenId);
      if (Array.isArray(buildings)) return buildings;
    } catch (e) {
      console.warn('[Autobuy Vehicles] API-Speicher fehlgeschlagen, nutze HTML-Fallback:', e);
    }

    return await getBuildingsOfLeitstelleFallback(leitstellenId, delayAfterFetch);
  }

  //----------------------------------------------
  // FAHRZEUGE LESEN
  //----------------------------------------------
  async function getVehiclesOfLeitstelle(leitstellenId) {
    // Zentrale Fahrzeugübersicht der Leitstelle ist weiterhin effizienter als pro Gebäude /vehicles aufzurufen.
    const tabLink = document.querySelector(`a[href="#tab_vehicle"]`);
    if (tabLink) tabLink.click();

    let tries = 0;
    while (tries < 50) {
      const rows = document.querySelectorAll('#tab_vehicle tr');
      if (rows.length > 0) break;
      await delay(100);
      tries++;
    }

    const vehicles = [];
    const rows = document.querySelectorAll('#tab_vehicle tr');

    rows.forEach(tr => {
      let buildingId = tr.getAttribute('building_id') || tr.getAttribute('data-building_id');
      if (!buildingId) {
        const link = tr.querySelector("a[href*='/buildings/']");
        if (link) buildingId = link.href.split('/buildings/')[1].split('/')[0];
      }

      tr.querySelectorAll('img[vehicle_type_id]').forEach(img => {
        vehicles.push({
          type: Number(img.getAttribute('vehicle_type_id')),
          building: Number(buildingId)
        });
      });
    });

    return vehicles.filter(v => Number.isFinite(v.building) && Number.isFinite(v.type));
  }

  async function getVehiclesOfBuilding(buildingId) {
    const res = await fetch(`/buildings/${buildingId}/vehicles`, { credentials: 'same-origin' });
    const html = await res.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');
    return Array.from(doc.querySelectorAll('img[vehicle_type_id]'))
      .map(img => Number(img.getAttribute('vehicle_type_id')))
      .filter(Number.isFinite);
  }

  //----------------------------------------------
  // KAUF
  //----------------------------------------------
  async function buyVehicle(buildingId, vehicleType) {
    const token = getCsrfToken();
    const response = await fetch(`/buildings/${buildingId}/vehicle/${buildingId}/${vehicleType}/credits?building=${buildingId}`, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-CSRF-Token': token,
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: new URLSearchParams({
        _method: 'get',
        authenticity_token: token
      }),
      redirect: 'manual'
    });

    if (response.status >= 400) {
      throw new Error(`Fahrzeug ${vehicleType} konnte bei Gebäude ${buildingId} nicht gekauft werden. Status: ${response.status}`);
    }
  }

  async function buyMissingVehiclesForBuilding(building, config, vehicleCountMap, delayPerVehicle) {
    for (const [vehicleTypeRaw, wanted] of config.vehicles) {
      const vehicleType = Number(vehicleTypeRaw);
      if (!Number.isInteger(vehicleType) || !Number.isInteger(wanted) || wanted <= 0) continue;

      const key = `${building.id}:${vehicleType}`;
      const current = vehicleCountMap.get(key) || 0;
      const toBuy = Math.max(0, wanted - current);
      if (toBuy === 0) continue;

      for (let i = 0; i < toBuy; i++) {
        await buyVehicle(building.id, vehicleType);
        vehicleCountMap.set(key, (vehicleCountMap.get(key) || 0) + 1);
        if (delayPerVehicle > 0) await delay(delayPerVehicle);
      }
    }
  }

  //----------------------------------------------
  // AUTOBUY LEITSTELLE
  //----------------------------------------------
  async function autobuyForLeitstelle(leitstellenId, DELAY_PER_VEHICLE, DELAY_PER_BUILDING, DELAY_AFTER_FETCH) {
    setState('Lade Gebäude über API-Speicher…', 'info');
    const buildings = await getBuildingsOfLeitstelle(leitstellenId, DELAY_AFTER_FETCH);

    setState('Lade vorhandene Fahrzeuge…', 'info');
    const vehicles = await getVehiclesOfLeitstelle(leitstellenId);

    const vehicleCountMap = new Map();
    for (const v of vehicles) {
      const key = `${v.building}:${v.type}`;
      vehicleCountMap.set(key, (vehicleCountMap.get(key) || 0) + 1);
    }

    const targets = [];
    for (const b of buildings) {
      const cfg = await getConfigForType(Number(b.type ?? b.building_type));
      if (cfg && cfg.vehicles && cfg.vehicles.length) {
        targets.push({ building: b, config: cfg });
      }
    }

    if (targets.length === 0) {
      setState('Nichts zu tun', 'success');
      setTimeout(destroyNavbar, 1200);
      return;
    }

    let ok = 0;
    let err = 0;
    const total = targets.length;

    for (const t of targets) {
      if (!sessionStorage.getItem(RUN_FLAG)) break;

      const b = t.building;
      const config = t.config;

      try {
        setState(`${b.name}`, 'info');
        updateProgress(ok, err, total, `${b.name}`);
        await buyMissingVehiclesForBuilding(b, config, vehicleCountMap, DELAY_PER_VEHICLE);
        ok++;
      } catch (e) {
        console.error('[Autobuy Vehicles] Fehler bei Gebäude', b.id, b.name, e);
        err++;
      }

      updateProgress(ok, err, total);
      if (DELAY_PER_BUILDING > 0) await delay(DELAY_PER_BUILDING);
    }

    setState('Fertig', err ? 'warning' : 'success');
    setTimeout(destroyNavbar, 1500);
  }

