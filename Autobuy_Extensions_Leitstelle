    const panel = document.getElementById(SETTINGS_IDENTIFIER);
    if (!panel) return;

    async function initSelectForType(typeId) {
      const key = KEY_AUSBAUTEN_PREFIX + String(typeId);
      const labelTextStart = `${typeId} `;
      const formGroups = panel.querySelectorAll('.form-group, .setting, div');

      let select = null;
      for (const fg of formGroups) {
        const label = fg.querySelector('label');
        if (!label) continue;
        const txt = label.textContent.trim();
        if (!txt.startsWith(labelTextStart)) continue;
        const s = fg.querySelector('select[multiple]');
        if (s) { select = s; break; }
      }
      if (!select) return;

      const raw = await GM_getValue(key, '[]');
      const selectedIds = parseStoredExtensions(raw);

      if (selectedIds.length) {
        for (const opt of select.options) {
          const v = parseInt(opt.value, 10);
          opt.selected = selectedIds.includes(v);
        }
        select.dispatchEvent(new Event('change'));
      }

      select.addEventListener('change', async () => {
        const vals = Array.from(select.selectedOptions)
          .map(o => parseInt(o.value, 10))
          .filter(n => Number.isInteger(n));
        await GM_setValue(key, JSON.stringify(vals));
      });
    }

    for (const t of BUILDING_TYPES) {
      await initSelectForType(t.id);
    }

    return;
  }

  //----------------------------------------------
  // GEBÄUDE LADEN ÜBER API-SPEICHER / INDEXEDDB
  //----------------------------------------------
  async function loadApiBuildingsFromCache(maxAgeSeconds = 60) {
    if (typeof openDb !== 'function' || typeof updateBuildings !== 'function') {
      throw new Error('API-Speicher ist nicht verfügbar.');
    }

    const db = await openDb();
    await updateBuildings(db, maxAgeSeconds);

    // Robuster Loader: Die API-Speicher-Library ist nicht überall gleich exportiert.
    // Deshalb werden alle bekannten Varianten einzeln versucht, ohne den Leitstellenlauf direkt abzubrechen.
    const tryLoaders = [
      async () => {
        if (typeof getDataByIndex !== 'function') return null;
        return await getDataByIndex(db, 'buildings', 'building_type', IDBKeyRange.bound(0, 999));
      },
      async () => {
        if (typeof getDataByIndex !== 'function') return null;
        return await getDataByIndex(db, 'buildings', 'building_type', IDBKeyRange.lowerBound(0));
      },
      async () => {
        if (typeof getAllData !== 'function') return null;
        return await getAllData(db, 'buildings');
      },
      async () => {
        if (typeof getData !== 'function') return null;
        return await getData(db, 'buildings');
      },
      async () => {
        return await new Promise((resolve, reject) => {
          const transaction = db.transaction('buildings', 'readonly');
          const store = transaction.objectStore('buildings');
          const request = store.getAll();
          request.onsuccess = () => resolve(request.result || []);
          request.onerror = () => reject(request.error || new Error('Gebäude konnten nicht aus IndexedDB geladen werden.'));
        });
      }
    ];

    let lastError = null;

    for (const loader of tryLoaders) {
      try {
        const data = await loader();
        if (Array.isArray(data)) {
          console.log('[Autobuy Extensions] Gebäude aus API-Speicher geladen:', data.length);
          return data.map(normalizeApiBuilding);
        }
      } catch (e) {
        lastError = e;
        console.warn('[Autobuy Extensions] Gebäude-Loader fehlgeschlagen, versuche nächsten Loader:', e);
      }
    }

    throw lastError || new Error('Keine Gebäude aus API-Speicher geladen.');
  }

  async function getBuildingsOfLeitstelle(leitstellenId) {
    const targetId = Number(leitstellenId);
    const allBuildings = await loadApiBuildingsFromCache(60);

    return allBuildings
      .filter(b => b.leitstelle_building_id === targetId)
      .filter(b => !buildingsIDToIgnore.includes(Number(b.building_type)))
      .sort((a, b) => a.id - b.id);
  }

  async function getApiBuildingById(buildingId) {
    const id = Number(buildingId);
    const allBuildings = await loadApiBuildingsFromCache(60);
    return allBuildings.find(b => Number(b.id) === id) || null;
  }

