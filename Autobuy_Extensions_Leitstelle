  //----------------------------------------------
  function extensionIdFromApiExtension(ext) {
    const candidates = [ext.type_id, ext.type, ext.id, ext.extension_id];
    for (const c of candidates) {
      const n = toNumber(c);
      if (n !== null) return n;
    }
    return null;
  }

  function getAvailableExtensionsFromApiBuilding(building) {
    const apiExtensions = Array.isArray(building?.extensions) ? building.extensions : [];

    return apiExtensions
      .map(ext => ({ ...ext, abe_type_id: extensionIdFromApiExtension(ext) }))
      .filter(ext => ext.abe_type_id !== null)
      .filter(ext => ext.available !== false)
      .filter(ext => ext.enabled !== true)
      .map(ext => ext.abe_type_id);
  }

  async function getAvailableExtensionsFromHtml(buildingId) {
    const res = await fetch(`/buildings/${buildingId}`, { credentials: 'same-origin' });
    const html = await res.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');

    const extensions = Array.from(doc.querySelectorAll(`a[href*="/extension/credits/"]`))
      .map(a => {
        const match = a.getAttribute('href')?.match(/credits\/(\d+)\?/);
        return match ? parseInt(match[1], 10) : null;
      })
      .filter(id => id !== null);

    const specs = Array.from(doc.querySelectorAll(`a[href*="/building_specializations"]`))
      .map(a => {
        if (a.href.includes('factory_fire_brigade')) return 'factory_fire_brigade';
        if (a.href.includes('airport'))             return 'airport';
        if (a.href.includes('water_rescue'))        return 'water_rescue';
        return null;
      })
      .filter(x => x);

    const storages = Array.from(doc.querySelectorAll(`a[href*="/storage_upgrade/credits/"]`))
      .map(a => {
        const href = a.getAttribute('href') || '';
        if (href.includes('initial_containers')) return 'initial_containers';
        const m = href.match(/additional_containers_(\d+)/);
        return m ? `additional_containers_${m[1]}` : null;
      })
      .filter(x => x);

    return { extensions, specs, storages };
  }

  async function getAvailableActions(buildingId, apiBuilding, needsHtmlFallback) {
    const extensionsFromApi = getAvailableExtensionsFromApiBuilding(apiBuilding);

    // Für normale Ausbauten reicht API. HTML wird nur noch benötigt, wenn:
    // - keine API-Erweiterungen vorhanden sind
    // - Spezialisierungen oder Lager konfiguriert sind
    if (!needsHtmlFallback && extensionsFromApi.length > 0) {
      return { extensions: extensionsFromApi, specs: [], storages: [] };
    }

    if (!needsHtmlFallback && Array.isArray(apiBuilding?.extensions)) {
      return { extensions: extensionsFromApi, specs: [], storages: [] };
    }

    const htmlAvailable = await getAvailableExtensionsFromHtml(buildingId);
    return {
      extensions: extensionsFromApi.length ? extensionsFromApi : htmlAvailable.extensions,
      specs: htmlAvailable.specs,
      storages: htmlAvailable.storages
    };
  }

  async function buyExtension(buildingId, extensionId) {
    const token = getCsrfToken();
    const response = await fetch(`/buildings/${buildingId}/extension/credits/${extensionId}?redirect_building_id=${buildingId}`, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-CSRF-Token': token,
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: new URLSearchParams({
        _method: 'post',
        authenticity_token: token
      }),
      redirect: 'manual'
    });

    if (response.status >= 400) {
      throw new Error(`Ausbau ${extensionId} konnte bei Gebäude ${buildingId} nicht gekauft werden. Status: ${response.status}`);
    }
  }

  async function buySpecialization(buildingId, type) {
    const token = getCsrfToken();
    const response = await fetch(`/building_specializations?building_id=${buildingId}&pay_with=credits&type=${type}`, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-CSRF-Token': token,
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: new URLSearchParams({
        _method: 'post',
        authenticity_token: token
      }),
      redirect: 'manual'
    });

    if (response.status >= 400) {
      throw new Error(`Spezialisierung ${type} konnte bei Gebäude ${buildingId} nicht gekauft werden. Status: ${response.status}`);
    }
  }

  async function buyStorage(buildingId, storageName) {
    const token = getCsrfToken();
    const response = await fetch(`/buildings/${buildingId}/storage_upgrade/credits/${storageName}?redirect_building_id=${buildingId}`, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-CSRF-Token': token,
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: new URLSearchParams({
        _method: 'post',
        authenticity_token: token
      }),
      redirect: 'manual'
    });

    if (response.status >= 400) {
      throw new Error(`Lager ${storageName} konnte bei Gebäude ${buildingId} nicht gekauft werden. Status: ${response.status}`);
    }
  }

  function markExtensionAsBought(apiBuilding, extensionId) {
    if (!apiBuilding || !Array.isArray(apiBuilding.extensions)) return;
    const ext = apiBuilding.extensions.find(e => extensionIdFromApiExtension(e) === Number(extensionId));
    if (!ext) return;
    ext.enabled = true;
    ext.available = false;
  }

  async function extendBuilding(buildingId, config, DELAY_PER_ACTION, apiBuilding = null) {
    if (!config) return;

    const needsHtmlFallback = Boolean(
      (config.spezialisierung && config.spezialisierung.length) ||
      (config.lager && config.lager.length)
    );

    const available = await getAvailableActions(buildingId, apiBuilding, needsHtmlFallback);

    for (const a of config.ausbauten || []) {
      const extId = Number(a);
      if (!available.extensions.includes(extId)) continue;

      await buyExtension(buildingId, extId);
      markExtensionAsBought(apiBuilding, extId);
      await delay(DELAY_PER_ACTION);
    }

    for (const s of config.spezialisierung || []) {
      let type = '';
      if (s == 0 || s === 'factory_fire_brigade') type = 'factory_fire_brigade';
      if (s == 1 || s === 'airport')             type = 'airport';
      if (s == 2 || s === 'water_rescue')        type = 'water_rescue';
      if (!type || !available.specs.includes(type)) continue;

      await buySpecialization(buildingId, type);
      await delay(DELAY_PER_ACTION);
    }

    for (const l of config.lager || []) {
      const storageName =
        (l == 0 || l === 'initial_containers') ? 'initial_containers' :
        (typeof l === 'string' && l.startsWith('additional_containers_'))
          ? l
          : `additional_containers_${l}`;

      if (!available.storages.includes(storageName)) continue;

      await buyStorage(buildingId, storageName);
      await delay(DELAY_PER_ACTION);
    }
  }

  async function autobuyExtensionsForLeitstelle(leitstellenId, DELAY_PER_ACTION, DELAY_PER_BUILDING) {
    abeSetState('Lade Gebäude über API-Speicher…', 'info');

    const buildings = await getBuildingsOfLeitstelle(leitstellenId);
    const total = buildings.length;

    let ok = 0;
    let err = 0;

    for (const b of buildings) {
      const config = b.type ? await getConfigForType(Number(b.type)) : null;
      const hasWork = config && (
        (config.ausbauten?.length) ||
        (config.spezialisierung?.length) ||
        (config.lager?.length)
      );

      abeSetState(`Bearbeite ${b.name}…`, 'info');
      abeUpdateProgress(ok, err, total, b.name);

      if (!hasWork) {
        ok++;
        abeUpdateProgress(ok, err, total, b.name);
        await delay(DELAY_PER_BUILDING);
        continue;
      }

      try {
        await extendBuilding(b.id, config, DELAY_PER_ACTION, b);
        ok++;
      } catch (e) {
        console.error('[Autobuy Extensions] Fehler bei Gebäude', b.id, b.name, e);
        err++;
      }

      abeUpdateProgress(ok, err, total, b.name);
      await delay(DELAY_PER_BUILDING);
    }

    abeSetState('Autobuy Extensions abgeschlossen', err ? 'warning' : 'success');
    setTimeout(abeDestroyNavbar, 1500);
  }

  //----------------------------------------------
  // HAUPTLOGIK (Gebäudeseiten)
  //----------------------------------------------
  const titleDiv = Array.from(document.getElementsByTagName('h1'))
    .find(e => e.getAttribute('building_type') != null);
  if (!titleDiv) return;

  const buildingTypeID = Number(titleDiv.getAttribute('building_type'));
  const buildingId = Number(window.location.pathname.split('/').filter(Boolean).pop());

  const { DELAY_PER_ACTION, DELAY_PER_BUILDING } = await getConfiguredDelays();

  // Leitstelle
  if (buildingTypeID === 7) {
    function addAutobuyButtonToBuildingDetails() {
      const buildingDetailsElement = document.querySelector('.building-title ~ dl.dl-horizontal');
      if (!buildingDetailsElement) return;

      if (document.getElementById('abe-building-details-buttons')) return;

      const dtElement = document.createElement('dt');
      const dtTextElement = document.createElement('strong');
      dtTextElement.innerText = 'Erweiterungen kaufen:';
      dtElement.appendChild(dtTextElement);

      const buttonGroup = document.createElement('div');
      buttonGroup.id = 'abe-building-details-buttons';
      buttonGroup.className = 'btn-group';

      const btn = document.createElement('a');
      btn.href = '';
      btn.className = 'btn btn-default btn-xs';
      btn.innerText = 'Autobuy Extensions';

      const btnSettings = document.createElement('a');
      btnSettings.className = 'btn btn-default btn-xs';
      btnSettings.href = `/settings/index#${SETTINGS_IDENTIFIER}`;
      btnSettings.target = '_blank';

      const cog = document.createElement('span');
      cog.className = 'glyphicon glyphicon-cog';
      cog.title = 'Einstellungen';
      btnSettings.appendChild(cog);

      btn.addEventListener('click', async function (event) {
        event.preventDefault();

        if (btn.classList.contains('disabled')) return;
        btn.classList.add('disabled');

        abeCreateNavbar();
        abeSetState('Starte Autobuy…', 'info');
        abeUpdateProgress(0, 0, 1);

        try {
          await autobuyExtensionsForLeitstelle(
            buildingId,
            DELAY_PER_ACTION,
            DELAY_PER_BUILDING
          );
        } catch (e) {
          console.error('[Autobuy Extensions] Leitstellenlauf fehlgeschlagen', e);
          abeSetState('Fehler beim Leitstellenlauf', 'danger');
        }

        btn.classList.remove('disabled');
      });

      buttonGroup.append(btn, btnSettings);

      const ddElement = document.createElement('dd');
      ddElement.appendChild(buttonGroup);

      buildingDetailsElement.appendChild(dtElement);
      buildingDetailsElement.appendChild(ddElement);
    }

    addAutobuyButtonToBuildingDetails();
    return;
  }

  // Einzelgebäude
  if (buildingsIDToIgnore.indexOf(buildingTypeID) >= 0) return;

  const wrapperDIV = document.createElement('div');
  wrapperDIV.innerText = 'Autobuy Extensions:';
  wrapperDIV.style.padding = '15px 5px 15px 5px';
  titleDiv.parentNode.parentNode.insertBefore(wrapperDIV, titleDiv.parentNode.nextSibling);

  const btn = document.createElement('a');
  btn.className = 'btn btn-success btn-xs';
  btn.innerText = 'Autobuy (laut Einstellungen)';
  btn.style.margin = '5px';
  wrapperDIV.appendChild(btn);

  const btnSettings = document.createElement('a');
  btnSettings.className = 'btn btn-default btn-xs';
  btnSettings.href = `/settings/index#${SETTINGS_IDENTIFIER}`;
  btnSettings.target = '_blank';
  btnSettings.style.margin = '5px';
  const cog2 = document.createElement('span');
  cog2.className = 'glyphicon glyphicon-cog';
  cog2.title = 'Einstellungen';
  btnSettings.appendChild(cog2);
  wrapperDIV.appendChild(btnSettings);

  btn.addEventListener('click', async function () {
    const config = await getConfigForType(buildingTypeID);
    if (!config || (
      !(config.ausbauten && config.ausbauten.length) &&
      !(config.spezialisierung && config.spezialisierung.length) &&
      !(config.lager && config.lager.length)
    )) {
      alert('Für diesen Gebäudetyp sind keine Ausbauten in den Einstellungen hinterlegt.');
      return;
    }

    abeCreateNavbar();
    abeSetState('Kaufe Ausbauten…', 'info');
    abeUpdateProgress(0, 0, 1);

    try {
      const apiBuilding = await getApiBuildingById(buildingId).catch(() => null);
      await extendBuilding(buildingId, config, DELAY_PER_ACTION, apiBuilding);
      abeUpdateProgress(1, 0, 1);
      abeSetState('Fertig', 'success');
    } catch (e) {
      console.error('[Autobuy Extensions] Fehler beim Einzelgebäude', buildingId, e);
      abeUpdateProgress(0, 1, 1);
      abeSetState('Fehler', 'danger');
    }

    setTimeout(() => {
      abeDestroyNavbar();
      location.reload();
    }, 1200);
  });

})();
